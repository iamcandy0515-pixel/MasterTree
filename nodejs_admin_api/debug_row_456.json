  "content_blocks": [
    {
      "type": "text",
      "content": "01 기고식을 이용하여 기계고, 지반고를 구하시오."
    },
    {
      "type": "image",
      "content": "https://phqnxvehlcvruaavquay.supabase.co/storage/v1/object/public/tree-images/quizzes/1772340935817_u5s2k7_pasted_image.png"
    }
  ],
  "hint_blocks": [
    {
      "type": "text",
      "content": "기계고는 기준점(B.M) 높이에 후시를 더하여 계산"
    },
    {
      "type": "text",
      "content": "지반고는 기계고에서 전시를 빼서 계산"
    }
  ],
  "options": [
    {
      "type": "text",
      "content": "기계고, 지반고 계산"
    },
    {
      "type": "text",
      "content": "임도 노선 선정"
    }
  ],
  "correct_option_index": 0,
  "explanation_blocks": [
    {
      "type": "text",
      "content": "풀이순서: 기계고 및 지반고 계산\n공식 및 계산식: 기계고 = 이전 지반고 + 후시, 지반고 = 기계고 - 전시\n공식 및 계산식 적용:\n① 기계고 = 30 + 후시 = 30 + 2.3 = 32.3\n② 지반고 = 기계고 - 전시 = 32.3 - 3.2 = 29.1\n③ 기계고 = 지반고 + 후시 = 31.2 + 4.25 = 35.45\n④ 지반고 = 기계고 - 전시 = 35.45 - 2.1 = 33.35"
    }
  ],
