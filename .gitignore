# -------------------------------------------------------------------------
# MasterTreeApp Monorepo .gitignore
# 이 파일에 등록된 내용은 로컬에만 보존되고 GitHub에는 올라가지 않습니다.
# -------------------------------------------------------------------------

# --- Common Dependencies ---
node_modules/
.DS_Store
dist/
.turbo/
.temp_ag_kit/
antigravity-doc
tests/
others/
scripts/

# --- Build & Artifacts ---
build/
bin/
out/
*.out

# --- Flutter/Dart (Local Cache) ---
.dart_tool/
.packages
.pub-cache/
.pub/

# --- IDE Configs ---
.vscode/
.idea/

# --- !!! SECURITY & PRIVATE DATA (CRITICAL) !!! ---
.env
.env.*
.vercel/
!.vercel/project.json

# --- DEVELOPMENT ARTIFACTS & LOGS (LOCAL ONLY) ---
*.log
*.txt
*.analyze
*.csv
analyze_*
log_*
*_log.txt
repair_*.txt
inspect_*.txt
test_result.json

# --- IMPLEMENTATION PLANS & TASKS (KEEP LOCAL ONLY) ---
*-plan.md
*-plan-v*.md
*.plan
tasks/
design/tasks/
*.todo.md
ADMIN_TODO.md
TODO.md

# --- TEMPORARY & SCRATCH SCRIPTS ---
tmp/
nodejs_admin_api/tmp_*
nodejs_admin_api/test_*
nodejs_admin_api/temp_*
flutter_admin_app/tmp_*
flutter_user_app/tmp_*
temp_*.js
temp_*.ts
test_*.js
test_*.ts
test_*.dart
scratch_*.js
scratch_*.ts
